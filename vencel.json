{
  "version": 2,
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "/src/api/enviar-email.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/src/api/enviar-email",
      "dest": "/api/enviar-email.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}